# --- Anthropic (for synthesising training data) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Weights & Biases ---
WANDB_API_KEY=
WANDB_PROJECT=toolsmith
WANDB_ENTITY=

# --- HuggingFace Hub ---
HF_TOKEN=
HF_HUB_REPO_ID=<your-username>/toolsmith-qwen2.5-0.5b

# --- Training overrides (optional) ---
TOOLSMITH_BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
TOOLSMITH_OUTPUT_DIR=./outputs
TOOLSMITH_LORA_R=16
TOOLSMITH_LORA_ALPHA=32
TOOLSMITH_LR=2e-4
TOOLSMITH_EPOCHS=3
TOOLSMITH_BATCH_SIZE=4
TOOLSMITH_GRAD_ACCUM=4
