# --- LLM provider ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: fallback / alt provider
OPENAI_API_KEY=

# --- Tracing (optional) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=readrover
LANGSMITH_TRACING=false

# --- Model selection ---
READROVER_MODEL=claude-3-5-sonnet-latest
READROVER_TEMPERATURE=0.0

# --- Retrieval ---
READROVER_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
READROVER_CHROMA_PATH=./chroma_db
READROVER_TOP_K_PAPERS=5
READROVER_TOP_K_CHUNKS=8
READROVER_CHUNK_SIZE=1000
READROVER_CHUNK_OVERLAP=150

# --- Logging ---
READROVER_LOG_LEVEL=INFO
