<cell id="f49cc1c5">import numpy as np
import pandas as pd
from skmultilearn.problem_transform import LabelPowerset
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, hamming_loss
from sklearn.model_selection import train_test_split
from sklearn.neural_network import MLPClassifier
from sklearn.preprocessing import OrdinalEncoder
from sklearn.tree import DecisionTreeClassifier
</cell id="f49cc1c5">
<cell id="aeb20ec5">RANDOM_STATE = 0

rf_classifier = LabelPowerset(
    classifier=RandomForestClassifier(random_state=RANDOM_STATE),
    require_dense=[False, True],
)
dt_classifier = LabelPowerset(
    classifier=DecisionTreeClassifier(random_state=RANDOM_STATE),
    require_dense=[False, True],
)
nn_classifier = MLPClassifier(max_iter=400, random_state=RANDOM_STATE)</cell id="aeb20ec5">
<cell id="76a1f9be">train_df = pd.read_csv("train.csv")
test_df = pd.read_csv("test.csv", header=None)
train_labels = pd.read_csv("trainLabels.csv")
</cell id="76a1f9be">
<cell id="1186929e"># Preprocessing
# - YES/NO → 1/0, missing → -1
# - Object (hash-string) columns → deterministic integer codes via OrdinalEncoder,
#   fit on the union of train+test so codes are consistent across the two sets
#   *and* across runs. This replaces Python's built-in hash(), which is randomised
#   per process (PYTHONHASHSEED) and made results non-reproducible.

BINARY_MAP = {"YES": 1, "NO": 0, np.nan: -1}

merged_df = pd.merge(train_df, train_labels, on="id").replace(BINARY_MAP)
test_features = test_df.drop(columns=0).replace(BINARY_MAP)  # col 0 is an id
test_features.columns = [c for c in merged_df.columns if c.startswith("x")]

object_columns = merged_df.select_dtypes(include="object").columns.tolist()
if object_columns:
    encoder = OrdinalEncoder(handle_unknown="use_encoded_value", unknown_value=-1)
    encoder.fit(pd.concat([merged_df[object_columns], test_features[object_columns]]))
    merged_df[object_columns] = encoder.transform(merged_df[object_columns])
    test_features[object_columns] = encoder.transform(test_features[object_columns])

feature_cols = [c for c in merged_df.columns if c.startswith("x")]
label_cols = [c for c in merged_df.columns if c.startswith("y")]
X = merged_df[feature_cols]
y = merged_df[label_cols]
</cell id="1186929e">
<cell id="2095df29">X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.2, random_state=RANDOM_STATE
)</cell id="2095df29">
<cell id="702c48bc">rf_classifier.fit(np.array(X_train), np.array(y_train))
rf_pred = rf_classifier.predict(X_test)
print("Random Forest accuracy:", accuracy_score(y_test, rf_pred))
print("Random Forest hamming loss:", hamming_loss(y_test, rf_pred))</cell id="702c48bc">
<cell id="8cd3b8ed">nn_classifier.fit(np.array(X_train), np.array(y_train))
nn_pred = nn_classifier.predict(X_test)
print("Neural Network accuracy:", accuracy_score(y_test, nn_pred))</cell id="8cd3b8ed">
<cell id="6328e5d6">dt_classifier.fit(np.array(X_train), np.array(y_train))
dt_pred = dt_classifier.predict(X_test)
print("Decision Tree accuracy:", accuracy_score(y_test, dt_pred))</cell id="6328e5d6">
<cell id="4b54a91d"># Random Forest ~82%, Decision Tree ~72%, Neural Network ~25% (high variance).
# Random Forest wins, so we refit on the full training data and predict on test.
rf_classifier.fit(np.array(X), np.array(y))
test_predictions = rf_classifier.predict(test_features).todense()
final_pred = pd.DataFrame(test_predictions, columns=label_cols)
final_pred.insert(0, "id", 1698001 + final_pred.index)
display(final_pred)</cell id="4b54a91d">
<cell id="dc01acbc"># Kaggle-style submission format: one row per (id, label) pair.
# Vectorised with pd.melt — the previous iterrows + pd.concat loop was O(n²).
transformed_df = final_pred.melt(id_vars="id", var_name="label", value_name="pred")
transformed_df["id_label"] = (
    transformed_df["id"].astype(str) + "_" + transformed_df["label"]
)
transformed_df = transformed_df[["id_label", "pred"]]
print(transformed_df)</cell id="dc01acbc">
<cell id="73694f11">transformed_df.to_csv("NitheeshP-prediction-output.csv", index=False)</cell id="73694f11">